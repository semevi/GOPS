{
  "builds": [
    {
      "src": "apps/frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "apps/backend/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "apps/backend/src/index.ts" },
    { "src": "/(.*)", "dest": "apps/frontend/dist/$1" },
    { "handle": "filesystem" }
  ]
}
